APP_ENV=dev
# local works without API keys; switch to ollama/openai/anthropic/deepseek/custom as needed.
MODEL_BACKEND=local
REASONING_MODEL_BACKEND=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASONING_MODEL=
QUERY_REQUEST_TIMEOUT_MS=60000
STREAM_HEARTBEAT_SECONDS=6

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-5.4-codex
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_REASONING_MODEL=gpt-5.4-codex

ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_REASONING_MODEL=claude-sonnet-4-6

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-use-a-long-random-password
N8N_IMAGE=n8nio/n8n:replace-with-pinned-version

CHROMA_COLLECTION=local_rag_collection
CHROMA_PERSIST_DIR=./data/chroma
DATA_DIR=./data/docs
CORPUS_STORE_PATH=./data/chunks/chunks.jsonl
PARENT_STORE_PATH=./data/chunks/parents.jsonl
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=600
CHILD_CHUNK_OVERLAP=120

TOP_K=4
MAX_CONTEXT_CHUNKS=6
VECTOR_TOP_K=6
BM25_TOP_K=6
HYBRID_RRF_K=60
HYBRID_VECTOR_WEIGHT=0.95
HYBRID_BM25_WEIGHT=0.05
VECTOR_SIMILARITY_THRESHOLD=0.2
VECTOR_SIMILARITY_RELAXED_THRESHOLD=0.05

QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_WITH_LLM=false
QUERY_DECOMPOSE_ENABLED=true
QUERY_REWRITE_MAX_VARIANTS=6
RANK_FEATURE_ENABLED=true
RANK_FEATURE_SOURCE_WEIGHT=0.08
RANK_FEATURE_FRESHNESS_WEIGHT=0.07
RANK_FEATURE_RETRIEVAL_DIVERSITY_WEIGHT=0.05
DYNAMIC_RETRIEVAL_ENABLED=true
DYNAMIC_VECTOR_TOP_K_CAP=16
DYNAMIC_BM25_TOP_K_CAP=16
DYNAMIC_RERANKER_TOP_N_CAP=10

RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=45
RETRIEVAL_CACHE_MAX_ITEMS=256
RETRIEVAL_CACHE_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAIL_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
OTEL_TRACING_ENABLED=true

RETRIEVAL_PROFILE=advanced
CONSISTENCY_GUARD_ENABLED=true
CONSISTENCY_GUARD_SIMILARITY_THRESHOLD=0.55
WEB_DOMAIN_ALLOWLIST=gov.cn,gov,edu,org,nist.gov,cisa.gov,mitre.org,wikipedia.org,owasp.org,microsoft.com,openai.com
WEB_MIN_SOURCE_SCORE=0.2
ANSWER_SAFETY_SCAN_ENABLED=true
SLO_P95_LATENCY_MS_THRESHOLD=3000
SLO_ERROR_RATE_PERCENT_THRESHOLD=5
SLO_GROUNDING_SUPPORT_RATIO_THRESHOLD=0.6

ENABLE_RERANKER=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5

GRAPH_EXTRACTION_MODE=llm
GRAPH_TRIPLET_BATCH_CHARS=2200

SESSIONS_DIR=./data/sessions
UPLOADS_DIR=./data/uploads
AUTO_INGEST_ENABLED=false
AUTO_INGEST_INTERVAL_SECONDS=3
AUTO_INGEST_WATCH_DOCS=true
AUTO_INGEST_WATCH_UPLOADS=true
AUTO_INGEST_RECURSIVE=true
USERS_FILE=./data/security/users.json
AUTH_SESSIONS_FILE=./data/security/auth_sessions.json
AUTH_TOKEN_TTL_HOURS=24
APP_DB_PATH=./data/app.db
AUTH_LOGIN_MAX_FAILURES=8
AUTH_LOGIN_WINDOW_SECONDS=300

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/callback
AUTH_REGISTER_MAX_ATTEMPTS=12
AUTH_REGISTER_WINDOW_SECONDS=300
ADMIN_CREATE_APPROVAL_TOKEN=
ADMIN_CREATE_APPROVAL_TOKEN_HASH=
API_SETTINGS_ENCRYPTION_KEY=
API_BASE_URL_ALLOWLIST=
API_BASE_URL_ALLOW_PRIVATE=false
API_BASE_URL_DNS_CHECK=true
UPLOAD_MAX_FILES=20
UPLOAD_MAX_FILE_BYTES=20971520
UPLOAD_MAX_TOTAL_BYTES=104857600
UPLOAD_READ_CHUNK_BYTES=1048576
TESSERACT_CMD=
TESSERACT_LANG=chi_sim+eng
TESSDATA_PREFIX=
OCR_PREPROCESS_ENABLED=true
OCR_UPSCALE_MIN_SIDE=1200
OCR_PSM_MODES=6,11,3
PEOPLE_DETECTION_ENABLED=true
PEOPLE_DETECTION_MODE=face
IMAGE_CAPTION_ENABLED=false
IMAGE_CAPTION_BACKEND=auto
OPENAI_VISION_MODEL=gpt-4.1-mini
OLLAMA_VISION_MODEL=llava:7b
